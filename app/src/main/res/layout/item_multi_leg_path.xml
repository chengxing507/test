<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 路线摘要 - 大号显示 -->
        <TextView
            android:id="@+id/tv_segments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/md3_on_surface"
            android:lineSpacingExtra="3dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md3_outline_variant"
            android:layout_marginVertical="6dp" />

        <!-- 换乘信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/md3_secondary"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tv_duration_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/md3_on_primary_container"
                android:background="@color/md3_primary_container"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 详细路线 -->
        <TextView
            android:id="@+id/tv_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/md3_on_surface_variant"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
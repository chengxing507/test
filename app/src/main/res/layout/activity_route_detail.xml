<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md3_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/md3_primary"
        android:elevation="4dp"
        app:title="🚉 路线详情"
        app:titleTextColor="@color/md3_on_primary" />

    <TextView
        android:id="@+id/tv_route_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/md3_on_surface"
        android:background="@color/md3_primary_container" />

    <TextView
        android:id="@+id/tv_stops"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="@color/md3_on_surface_variant"
        android:lineSpacingExtra="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="← 返回"
        style="@style/Widget.Material3.Button.TextButton" />
</LinearLayout>
